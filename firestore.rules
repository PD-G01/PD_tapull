rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // ユーザーコレクション（user）
    match /user/{userId} {
      // 認証済みユーザーは自分のデータを読み書き可能
      allow read: if request.auth != null && request.auth.uid == userId;
      // 認証済みユーザーは他のユーザーの基本情報（名前など）を読み取り可能（チャット用）
      allow get: if request.auth != null;
      // 新規登録時は自分のUIDでデータを作成可能
      allow create: if request.auth != null && request.auth.uid == userId;
      // 更新は自分のデータのみ可能
      allow update: if request.auth != null && request.auth.uid == userId;
      // 削除は自分のデータのみ可能
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // チャットルームコレクション（chatRooms）
    match /chatRooms/{roomId} {
      // 単一ドキュメントの読み取り（getDocなど）
      allow get: if request.auth != null && 
                    resource.data.members != null &&
                    request.auth.uid in resource.data.members;
      
      // クエリでの取得（getDocs, onSnapshotなど）
      // where句でmembersフィールドをフィルタリングする必要がある
      // 各ドキュメントはallow getの条件でチェックされる
      allow list: if request.auth != null;
      
      // ルームの作成（認証済みユーザーなら誰でも作成可能）
      allow create: if request.auth != null &&
                       request.resource.data.members != null &&
                       request.auth.uid in request.resource.data.members;
      
      // ルームの更新（メンバーのみ可能）
      allow update: if request.auth != null && 
                       resource.data.members != null &&
                       request.auth.uid in resource.data.members;
      
      // メッセージサブコレクション
      match /messages/{messageId} {
        // メッセージの読み取り（ルームのメンバーのみ）
        // 親ルームのメンバーチェックは上位ルールで行われる
        allow read: if request.auth != null;
        
        // メッセージの作成（送信者のみ）
        allow create: if request.auth != null && 
                         request.resource.data.senderId == request.auth.uid;
        
        // メッセージの更新・削除（送信者のみ）
        allow update, delete: if request.auth != null && 
                                  resource.data.senderId == request.auth.uid;
      }
    }
    
    // その他のコレクションは必要に応じて追加
    match /{document=**} {
      allow read, write: if false; // デフォルトは拒否
    }
  }
}
