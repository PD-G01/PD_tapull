rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // ユーザーコレクション（user）
    match /user/{userId} {
      // 認証済みユーザーは自分のデータを読み書き可能
      allow read: if request.auth != null && request.auth.uid == userId;
      // 新規登録時は自分のUIDでデータを作成可能
      allow create: if request.auth != null && request.auth.uid == userId;
      // 更新は自分のデータのみ可能
      allow update: if request.auth != null && request.auth.uid == userId;
      // 削除は自分のデータのみ可能
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // チャットルームコレクション（chatRooms）
    match /chatRooms/{roomId} {
      // 単一ドキュメントの読み取り（getDocなど）
      allow get: if request.auth != null && 
                    resource.data.members != null &&
                    request.auth.uid in resource.data.members;
      
      // クエリでの取得（getDocs, onSnapshotなど）
      // listルールを定義しないことで、クエリはgetルールに基づいて評価される
      // これにより、各ドキュメントがgetルール（メンバーチェック）を満たす場合のみクエリが成功する
      // クライアント側でwhere('members', 'array-contains', currentUser.uid)を指定する必要がある
      // 悪意のあるユーザーがmembersフィールドを含まないクエリを実行しても、
      // 各ドキュメントがgetルールを満たさないため、クエリは失敗する
      
      // ルームの作成（認証済みユーザーなら誰でも作成可能）
      allow create: if request.auth != null &&
                       request.resource.data.members != null &&
                       request.auth.uid in request.resource.data.members &&
                       request.resource.data.keys().hasOnly(['members', 'title', 'displayName', 'createdAt', 'ownerUid', 'isOneOnOne']) &&
                       request.resource.data.members.size() == 2 &&
                       request.resource.data.isOneOnOne == true;
      
      // ルームの更新（メンバーのみ可能、かつ許可フィールドのみ）
      allow update: if request.auth != null && 
                       resource.data.members != null &&
                       request.auth.uid in resource.data.members &&
                       request.resource.data.keys().hasOnly(['lastMessage', 'updatedAt']);
      
      // メッセージサブコレクション
      match /messages/{messageId} {
        // メッセージの読み取り（ルームのメンバーのみ）
        // サブコレクションのルールは親ドキュメントのルールを継承しないため、
        // 明示的に親ルームのメンバーチェックが必要
        function isRoomMember(roomId) {
          return request.auth != null &&
                 get(/databases/$(database)/documents/chatRooms/$(roomId)).data.members != null &&
                 request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.members;
        }
        allow read: if isRoomMember(roomId);
        
        // メッセージの作成（送信者のみ、かつルームのメンバーのみ）
        allow create: if request.auth != null && 
                         request.resource.data.senderId == request.auth.uid &&
                         get(/databases/$(database)/documents/chatRooms/$(roomId)).data.members != null &&
                         request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.members;
        
        // メッセージの更新・削除（送信者のみ）
        allow update, delete: if request.auth != null && 
                                  resource.data.senderId == request.auth.uid;
      }
      
      // プレゼンスサブコレクション（オンライン状態管理）
      match /presence/{userId} {
        // ルームのメンバーは全員のpresence情報を読み取り可能
        allow read: if request.auth != null && 
                      get(/databases/$(database)/documents/chatRooms/$(roomId)).data.members != null &&
                      request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.members;
        
        // 自分のpresenceドキュメントのみ作成可能
        allow create: if request.auth != null && 
                         request.auth.uid == userId &&
                         request.resource.data.userId == userId;
        
        // 自分のpresenceドキュメントのみ更新可能
        allow update: if request.auth != null && 
                         request.auth.uid == userId &&
                         resource.data.userId == userId;
        
        // 自分のpresenceドキュメントのみ削除可能
        allow delete: if request.auth != null && 
                         request.auth.uid == userId;
      }
    }
    
    // その他のコレクションは必要に応じて追加
    match /{document=**} {
      allow read, write: if false; // デフォルトは拒否
    }
  }
}
