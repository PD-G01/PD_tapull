rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================================================
    // ⬇️ ここを追加: 食品提供（offer）用ルール
    // ==================================================
    match /offer/{offerId} {
      // ログインしていれば誰でも見れる
      allow read: if request.auth != null;
      
      // 作成: ログインしていて、かつデータ内のuser_idが本人の場合のみ許可
      allow create: if request.auth != null && 
                       request.resource.data.user_id == request.auth.uid;

      // 更新・削除: 作成者本人のみ許可
      allow update, delete: if request.auth != null && 
                               resource.data.user_id == request.auth.uid;
    }

    // ユーザーコレクション（user）
    match /user/{userId} {
      allow read: if request.auth != null;
      allow get: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    // プロフィールコレクション（読み取り専用）
    match /profiles/{document=**} {
      allow read: if request.auth != null;
    }
    
    // チャットルームコレクション（chatRooms）
    match /chatRooms/{roomId} {
      allow get: if request.auth != null &&
                    resource.data.members != null &&
                    request.auth.uid in resource.data.members;
      allow list: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.members != null &&
                       request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null &&
                       resource.data.members != null &&
                       request.auth.uid in resource.data.members;
      
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null &&
                         request.resource.data.senderId == request.auth.uid;
        allow update, delete: if request.auth != null &&
                                 resource.data.senderId == request.auth.uid;
      }
    }
    
    // その他すべて拒否（セキュリティの基本）
=======
    // チャットルームコレクション（chatRooms）
    match /chatRooms/{roomId} {
      // 単一ドキュメントの読み取り（getDocなど）
      allow get: if request.auth != null && 
                    resource.data.members != null &&
                    request.auth.uid in resource.data.members;
      
      // クエリでの取得（getDocs, onSnapshotなど）
      // listルールを定義しないことで、クエリはgetルールに基づいて評価される
      // これにより、各ドキュメントがgetルール（メンバーチェック）を満たす場合のみクエリが成功する
      // クライアント側でwhere('members', 'array-contains', currentUser.uid)を指定する必要がある
      // 悪意のあるユーザーがmembersフィールドを含まないクエリを実行しても、
      // 各ドキュメントがgetルールを満たさないため、クエリは失敗する
      
      // ルームの作成（認証済みユーザーなら誰でも作成可能）
      allow create: if request.auth != null &&
                       request.resource.data.members != null &&
                       request.auth.uid in request.resource.data.members &&
                       request.resource.data.keys().hasOnly(['members', 'title', 'displayName', 'createdAt', 'updatedAt', 'lastMessage', 'isOneOnOne', 'membersInfo']) &&
                       request.resource.data.members.size() == 2 &&
                       request.resource.data.isOneOnOne == true;
      
      // ルームの更新（メンバーのみ可能、かつ許可フィールドのみ）
      allow update: if request.auth != null && 
                  resource.data.members != null &&
                  request.auth.uid in resource.data.members &&
                  request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'updatedAt']);
      
      // メッセージサブコレクション
            function isRoomMember() {
        return request.auth != null &&
               get(/databases/$(database)/documents/chatRooms/$(roomId)).data.members != null &&
               request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.members;
      }

      // メッセージサブコレクション
      match /messages/{messageId} {
        // メッセージの読み取り（ルームのメンバーのみ）
        allow read: if isRoomMember();
        
        // メッセージの作成（送信者のみ、かつルームのメンバーのみ）
        allow create: if request.auth != null && 
                         request.resource.data.senderId == request.auth.uid &&
                         isRoomMember();
        
        // メッセージの更新・削除（送信者のみ）
        allow update, delete: if request.auth != null && 
                                  resource.data.senderId == request.auth.uid;
      }
      
      // プレゼンスサブコレクション（オンライン状態管理）
      match /presence/{userId} {
        // ルームのメンバーは全員のpresence情報を読み取り可能
        allow read: if isRoomMember();

        // 自分のpresenceドキュメントのみ作成可能
        allow create: if request.auth != null && 
                         request.auth.uid == userId &&
                         request.resource.data.userId == userId;
        
        // 自分のpresenceドキュメントのみ更新可能
        allow update: if request.auth != null && 
                         request.auth.uid == userId &&
                         resource.data.userId == userId;
        
        // 自分のpresenceドキュメントのみ削除可能
        allow delete: if request.auth != null && 
                         request.auth.uid == userId;
      }
    }
    
    // その他のコレクションは必要に応じて追加
    }
  }
}